# 複製成 .env 並填入你的值 (.env 已被 gitignore, 不會上傳)
# 必填
TELEGRAM_BOT_TOKEN="從 BotFather 取得的 token"
TELEGRAM_CHAT_ID="你的 chat id"
# 選填 (預設值見括號)
MM_DATA_DIR="data_adj"        # 股票資料夾
MM_WEB_PORT=8800              # 儀表板埠
# MM_WEB_URL="http://你的IP:8800"  # 設了 /chart 才會給可點連結
BOT_GOLD_WATCH=1              # 黃金背景監控 (1開/0關)
BOT_TXF_WATCH=1              # 台指盤中監控
BOT_GRAIN_WATCH=1            # 穀物價差監控
BOT_WEB=1                   # 儀表板伺服器
BOT_AUTO_UPDATE=0           # 終端機手動跑時建議關閉自動 git pull 重啟
