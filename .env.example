# Telegram 策略機器人設定範本
# 複製成 .env 並填入你的值, 再 source 它 (或直接 export 到 shell)
#   cp .env.example .env   &&   nano .env   &&   source .env
# 注意: .env 已被 .gitignore 忽略, 切勿把 token 推上 GitHub

export TELEGRAM_BOT_TOKEN="從 BotFather /newbot 或 /revoke 取得的新 token"
export TELEGRAM_CHAT_ID=""   # 留空; 第一次對 bot 送 /start 會回你的 chat id, 再填回來鎖定
export MM_DATA_DIR="/Users/jensenchen/money maker/adjusted_data"

# 自動同步雲端最新策略 (1=開啟[預設] / 0=關閉)。開啟後每小時 git pull, 有更新自動重啟
export BOT_AUTO_UPDATE="1"
# 由本機器人也做每日 08:00 推播 (1=開啟)。預設不開, 因 GitHub Actions 已負責
export BOT_DAILY_SCAN="0"
